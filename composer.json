{
    "name": "slam/basepath",
    "type": "library",
    "description": "PHP middleware to remove a path prefix from request uri",
    "homepage": "https://github.com/lansoweb/basepath",
    "license": "MIT",
    "authors": [
        {
            "name": "Leandro Silva",
            "homepage": "http://leandrosilva.info/"
        }
    ],
    "require": {
        "php": "^7.4 || ^8.0",
        "mezzio/mezzio-helpers": "^5.4.0",
        "psr/container": "^1.1.1",
        "psr/http-message": "^1.0.1",
        "psr/http-server-handler": "^1.0.1",
        "psr/http-server-middleware": "^1.0.1"
    },
    "require-dev": {
        "ext-json": "*",
        "laminas/laminas-coding-standard": "^2.1.4",
        "laminas/laminas-diactoros": "^2.5.0",
        "malukenho/mcbumpface": "^1.1.5",
        "phpstan/phpstan": "^0.12.81",
        "phpstan/phpstan-phpunit": "^0.12.18",
        "phpunit/phpunit": "^9.5.2",
        "squizlabs/php_codesniffer": "^3.5.8"
    },
    "extra": {
        "mc-bumpface": {
            "stripVersionPrefixes": true
        }
    },
    "autoload": {
        "psr-4": {
            "LosMiddleware\\BasePath\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LosMiddleware\\BasePathTest\\": "test/"
        }
    }
}
